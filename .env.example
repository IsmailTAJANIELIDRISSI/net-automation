# ── BADR ──────────────────────────────────────────────────────────────────────
BADR_URL=http://badr.douane.gov.ma
BADR_USERNAME=your_badr_username
BADR_PASSWORD=your_badr_password

# Path to your Edge executable (with USB certificate profile)
EDGE_PATH=C:\Program Files (x86)\Microsoft\Edge\Application\msedge.exe

# CDP remote debugging port (any free port)
BADR_CDP_PORT=9222

# Dedicated Edge user data dir (keeps certificate loaded)
BADR_PROFILE_DIR=C:\Temp\badr-edge-profile

# Bureau and operateur codes (defaults match CASA/NOUASSER-FRET + RAM)
BADR_BUREAU_CODE=301
BADR_BUREAU_LABEL=CASA/NOUASSER-FRET(301)(301)
BADR_OPERATEUR_CODE=1063
BADR_OPERATEUR_LABEL=CIE NATIONALE ROYAL AIR MAROC(81/9667)

# BADR “Lot de dédouanement” retry (when 0 rows are returned)
# BADR_SEARCH_WINDOW_DAYS=6
# BADR_SEARCH_RETRY_ATTEMPTS=2
# BADR_SEARCH_RETRY_SHIFT_DAYS=6
# BADR_SEARCH_RETRY_START_EXTRA_DAYS=1

# ── PORTNET ───────────────────────────────────────────────────────────────────
PORTNET_USERNAME=your_portnet_username
PORTNET_PASSWORD=your_portnet_password

# Annex PDFs are cached under each LTA folder: <LTA>/compress/<name>_compressed.pdf
# Set true to always call iLovePDF/Adobe again (ignore cache when retesting).
# PORTNET_IGNORE_COMPRESS_CACHE=false

# ── EMAIL NOTIFICATIONS ───────────────────────────────────────────────────────
EMAIL_ENABLED=false
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM=automation@yourcompany.com
EMAIL_TO=recipient@yourcompany.com

# ── GENERAL ───────────────────────────────────────────────────────────────────
HEADLESS=false
SLOW_MO=50
TIMEOUT=120000
LOGS_DIR=logs
